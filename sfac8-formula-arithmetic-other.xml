          xlink:to='LABEL_FILTER_CONCEPT_Balance_Assets'
          order='1.0'
          complement='false'
          cover='true'
          />
 <variable:variableFilterArc xlink:type='arc' xlink:arcrole='http://xbrl.org/arcrole/2008/variable-filter'
          xlink:from='LABEL_VARIABLE_Revenues'
          xlink:to='LABEL_FILTER_CONCEPT_Revenues'
