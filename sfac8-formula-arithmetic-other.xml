 <!-- ARC between VARIABLES and PERIOD Filters -->
 <variable:variableFilterArc xlink:type='arc' xlink:arcrole='http://xbrl.org/arcrole/2008/variable-filter'
          xlink:from='LABEL_VARIABLE_BalanceStart_Equity'
          xlink:to='LABEL_FILTER_PERIOD_BalanceStart'
          order='1.0'
          complement='false'
          cover='true'
          />
 <variable:variableFilterArc xlink:type='arc' xlink:arcrole='http://xbrl.org/arcrole/2008/variable-filter'
          xlink:from='LABEL_VARIABLE_BalanceEnd_Liabilities'
          xlink:to='LABEL_FILTER_PERIOD_BalanceEnd'
          order='1.0'
          complement='false'
          cover='true'
          />
<variable:variableFilterArc xlink:type='arc' xlink:arcrole='http://xbrl.org/arcrole/2008/variable-filter'
