          xlink:to='LABEL_FILTER_CONCEPT_Gains'
          order='1.0'
          complement='false'
          cover='true'
          />
<variable:variableFilterArc xlink:type='arc' xlink:arcrole='http://xbrl.org/arcrole/2008/variable-filter'
          xlink:from='LABEL_VARIABLE_Losses'
          xlink:to='LABEL_FILTER_CONCEPT_Losses'
          order='1.0'
          complement='false'
          cover='true'
          />
 <variable:variableFilterArc xlink:type='arc' xlink:arcrole='http://xbrl.org/arcrole/2008/variable-filter'
