 <variable:factVariable xlink:type='resource' xlink:label='LABEL_VARIABLE_DistributionsToOwners'
          bindAsSequence='false'
          />


 <!--  ARC from VARIABLES to CONCEPT FILTERS -->
 <variable:variableFilterArc xlink:type='arc' xlink:arcrole='http://xbrl.org/arcrole/2008/variable-filter'
          xlink:from='LABEL_VARIABLE_BalanceStart_Equity'
          xlink:to='LABEL_FILTER_CONCEPT_Balance_Equity'
          order='1.0'
          complement='false'
          cover='true'
          />
 <variable:variableFilterArc xlink:type='arc' xlink:arcrole='http://xbrl.org/arcrole/2008/variable-filter'
          xlink:from='LABEL_VARIABLE_BalanceEnd_Liabilities'
          xlink:to='LABEL_FILTER_CONCEPT_Balance_Liabilities'
